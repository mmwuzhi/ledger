{
  "expo": {
    "name": "MoneyBook",
    "slug": "moneybook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "moneybook",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moneybook.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.moneybook.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      ["expo-camera", { "cameraPermission": "允许 MoneyBook 使用相机拍摄小票" }],
      ["expo-image-picker", { "photosPermission": "允许 MoneyBook 访问相册选择小票图片" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
