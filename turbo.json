{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": ["TURSO_DATABASE_URL", "TURSO_AUTH_TOKEN", "SITE_PASSWORD"]
    },
    "dev": { "cache": false, "persistent": true },
    "test": { "dependsOn": ["^build"] },
    "lint": {},
    "type-check": { "dependsOn": ["^build"] }
  }
}
